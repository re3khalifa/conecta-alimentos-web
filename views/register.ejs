  <!DOCTYPE html>
  <html lang="es-MX">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Registro | Conecta Alimentos</title>
  </head>
  <body>

    <%- include('layout/header', { title: 'Registro' }) %>

    <nav class="breadcrumb container">
      <a href="/">Inicio</a> / <span>Registro</span>
    </nav>

    <main class="container section">
      <section class="form-container">
        <div class="form-card">
          <h2 class="page-title">Crear cuenta</h2>
          <p class="page-subtitle">Regístrate para acceder a la plataforma.</p>

          <form id="registerForm" novalidate>

            <label>Email</label>
            <input id="email" name="email" type="email"
              placeholder="correo@ejemplo.com" required />

            <label>Contraseña</label>
            <input id="password" name="password" type="password"
              placeholder="Mínimo 8 caracteres" required minlength="8" />

            <label>Tipo de cuenta</label>
            <select id="role" name="role">
              <option value="user">Usuario — quiero ver y reservar ofertas</option>
              <option value="commerce">Comercio — quiero publicar ofertas</option>
            </select>

          <div class="form-check mt-3">
            <input
            class="form-check-input"
            type="checkbox"
            id="privacyAccepted"
            name="privacyAccepted"
            required
            >

            <label class="form-check-label" for="privacyAccepted">
            He leído y acepto el
            <a href="/docs/aviso_privacidad_conecta_alimentos.pdf" target="_blank">
            Aviso de Privacidad
            </a>
            </label>
          </div>

            <p id="formMsg" class="form-msg" style="min-height:20px; font-size:13px;"></p>

            <button class="btn" type="submit" id="submitBtn">Registrarme</button>
            <a class="btn btn-outline" href="/auth/login">Ya tengo cuenta</a>

          </form>

          <script src="/js/register.js" defer></script>
        </div>
      </section>
    </main>

    <%- include('layout/footer') %>

  </body>
  </html>
