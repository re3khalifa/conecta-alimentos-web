<!DOCTYPE html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/style.css" />
    <title>Ver Detalle</title>
  </head>
  <body>
<%- include('layout/header', { title: 'Detalle de oferta' }) %>

<nav class="breadcrumb container">
  <a href="/">Inicio</a> / <a href="/ofertas">Ofertas</a> / <span>Detalle</span>
</nav>

<main class="container section">

  <div class="detail-wrap">

    <section class="stack" style="gap:14px;">
      <div class="card">
        <h3>Ubicación</h3>
        <p class="muted">Google Maps.</p>

        <div class="map-embed">
          <iframe
            id="gmapFrame"
            src=""
            width="600"
            height="450"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>

        <div style="margin-top:10px;">
          <a id="gmapLink" class="btn btn-outline btn-small" href="#" target="_blank" rel="noreferrer">
            Abrir en Google Maps
          </a>
        </div>
      </div>

      <div class="card">
        <h3>Clima en la zona</h3>
        <p class="muted">API de terceros: Open-Meteo (datos en tiempo real).</p>
        <div id="weatherBox" class="muted">Cargando clima…</div>
      </div>
    </section>

    <aside class="card" id="detailCard">
      <h2 class="page-title">Cargando…</h2>
      <p class="muted">Obteniendo información de la oferta.</p>
      <a class="btn btn-outline" href="/ofertas" style="margin-top:12px;">Volver</a>
    </aside>

  </div>
</main>

<script>
  const OFFER_ID = "<%= typeof id !== 'undefined' ? id : '' %>";
  const USER_ROLE = "<%= user ? user.role : '' %>";
</script>
<script src="/js/offer-detail.js"></script>

<%- include('layout/footer') %>



<!-- Si ya usas mapas, deja tus scripts aquí -->
<!-- <script src="https://maps.googleapis.com/maps/api/js?key=TU_API_KEY"></script> -->
<!-- <script src="/js/maps.js"></script> -->


  </body>
</html>
